// ══════════════════════════════════════════════════════
// Firebase Firestore Security Rules — Plus Mathematics
// ══════════════════════════════════════════════════════
// ارفع الملف ده على Firebase Console → Firestore → Rules
// ══════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isActiveSubscriber() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.subscriptionActive == true;
    }
    function isParent() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/parents/$(request.auth.uid));
    }

    // ══ USERS ══
    // الطالب يقرأ ويعدل بياناته بس — الأدمن مش بيتحقق من هنا (Cloud Functions)
    match /users/{uid} {
      allow read: if isOwner(uid) || isParentOf(uid);
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isOwner(uid) && onlyUpdatesAllowedFields();
      // لا حذف من العميل
      allow delete: if false;
    }

    function onlyUpdatesAllowedFields() {
      // الطالب يقدر يعدل: الاسم، الهاتف، الإيميل فقط
      let allowed = ['name', 'phone', 'email'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    function isParentOf(uid) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/parents/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/parents/$(request.auth.uid)).data.studentId == uid;
    }

    // ══ USER DEVICES ══
    match /users/{uid}/devices/{devId} {
      allow read, write: if isOwner(uid);
    }

    // ══ PROGRESS ══
    match /progress/{uid} {
      allow read: if isOwner(uid) || isParentOf(uid);
      allow write: if isOwner(uid);
    }

    // ══ CONTENT ══
    // المحتوى متاح للمشتركين النشطين فقط
    match /content/{gradeKey}/{type}/{itemId} {
      allow read: if isActiveSubscriber();
      allow write: if false; // الكتابة من الأدمن فقط (content-manager)
    }

    // ══ BOOKS ══
    match /books/{bookId} {
      allow read: if isActiveSubscriber();
      allow write: if false;
    }

    // ══ CODES ══
    // الطالب يقدر يقرأ كود معين للتحقق — مش يشوف الكل
    match /codes/{codeId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ══ COUPONS ══
    match /coupons/{couponId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ══ PARENTS ══
    // ولي الأمر يقرأ ويعدل بياناته بس
    match /parents/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ══ SETTINGS ══
    // الإعدادات متاحة للقراءة للكل (سعر، دفع، إعلانات) — الكتابة من الأدمن
    match /settings/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // ══ TICKETS (نظام التذاكر) ══
    match /tickets/{ticketId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','updatedAt']);
      allow delete: if false;
    }

    // ══ OTPs ══ (تم إلغاؤها — لو محتاجها تاني)
    match /otps/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ══ ADMINS ══ — محمية تماماً من العميل
    match /admins/{adminId} {
      allow read, write: if false;
    }

    // ══ ACTIVITY LOG ══ — قراءة فقط من الأدمن
    match /activity/{logId} {
      allow read, write: if false;
    }

    // ══ ANNOUNCEMENTS (legacy) ══
    match /announcements/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
